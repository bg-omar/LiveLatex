{
  "manifest_version": 3,
  "name": "LiveLatex & ChatGPT Tools",
  "version": "3.0",
  "description": "Live KaTeX rendering, Document Structuring, Chat Tree & Sidebar Sorter.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LiveLatex Settings",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*"
      ],
      "css": ["katex.min.css"],
      "js": ["katex.min.js", "content.js"]
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "css": ["chatgpt.css"],
      "js": ["chatgpt.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*", "fetch_patch.js"],
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*"
      ]
    }
  ]
}